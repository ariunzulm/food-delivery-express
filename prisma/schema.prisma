generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  phoneNumber String
  role    Role     @default(USER) 
  age      Int?
}

model Food{
  id       Int      @id @default(autoincrement())
  foodName String   
  price String
  image String?
  ingredients String?

  category FoodCategory @relation(fields: [foodCategoryId], references: [id])
  foodCategoryId Int

  foodOrderItems FoodOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}

model FoodCategory{
  id Int @id @default(autoincrement())
  categoryName String

  foods Food[]

  createdAt DateTime @default(now())
  updatedAt     DateTime? @updatedAt
}


model FoodOrder{
  id Int @id @default(autoincrement()) @unique
  totalPrice String

  foodOrderItems FoodOrderItem[]

  status FoodOrderStatusEnum     @default(PENDING) 
  createdAt DateTime @default(now())
  updatedAt     DateTime? @updatedAt
}

model FoodOrderItem{
  id Int @id @default(autoincrement())
  quantity Int

  food Food @relation(fields: [foodId], references: [id])
  foodId Int

  order FoodOrder @relation(fields: [foodOrderId], references: [id])
  foodOrderId Int

  
  createdAt DateTime @default(now())
  updatedAt     DateTime? @updatedAt
}

enum Role { 
  USER 
  ADMIN 
}

enum FoodOrderStatusEnum { 
  PENDING 
  CANCELED
  DELIVERED
}